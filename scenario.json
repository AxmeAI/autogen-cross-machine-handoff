{
  "scenario_id": "autogen-cross-machine.demo.v1",
  "title": "AutoGen cross-machine handoff",
  "description": "AutoGen analyzer agent processes data via AXME durable delivery.",
  "agents": [
    {
      "role": "analyzer",
      "address": "autogen-analyzer-demo",
      "display_name": "AutoGen Analyzer Agent",
      "delivery_mode": "stream",
      "create_if_missing": true
    }
  ],
  "workflow": {
    "steps": [
      {
        "step_id": "analyze_data",
        "tool_id": "tool.agent.task.v1",
        "assigned_to": "analyzer",
        "step_deadline_seconds": 120
      }
    ]
  },
  "intent": {
    "type": "intent.autogen.analyze.v1",
    "payload": {
      "dataset": "quarterly_sales_2026_q1",
      "analysis_type": "trend_detection",
      "output_format": "summary"
    },
    "max_delivery_attempts": 3
  }
}
